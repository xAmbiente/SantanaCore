	<scenario_list key="5000032">
		<kor name="후크 일반" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}파이러트 세력에 대항하는 또다른 해적!{N}입으면 금은보화를 획득할 것 같은 느낌이 드는 복장 아이템!"/>
		<ger name="Normal Pirate(M)Costume" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Arrr! Einmal Pirat, immer Pirat!{N}Kleidet euch wie ein echter Piratenkapitän und versetzt eure Feinde in Angst und Schrecken!"/>
        <eng name="Normal Pirate(M)Costume" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Arrr! A pirate stays a pirate!{N}Look like a real pirate captain and bring shock and awe to your foes! "/>
		<fre name="Normal Pirate(M)Costume" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Arrr ! Pirate un jour, pirate toujours !{N}Adoptez le look d'un véritable pirate et imposez la peur et le respect auprès de vos ennemis !"/>
		<spa name="Normal Pirate(M)Costume" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}¡Arrr! ¡Un pirata siempre será un pirata!{N}Con este Costume te verás como un verdadero pirata y seguramente espantarás a tus enemigos! "/>
		<ita name="Normal Pirate(M)Costume" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Arrr! Un pirata è sempre un pirata!{N}Vesti i panni di un vero capitano pirata e terrorizza i tuoi  nemici! "/>
		<rus name="Normal Pirate(M)Costume" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Карамба! Пират он же всегда пират! {N}Станьте капитаном пиратского корабля и заставьте врагов трепетать!"/>
		<tur name="Normal Korsan(E)  Kostümü" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Arrr! Bir korsan hep korsan kalır!{N}Gerçek bir korsan kaptan gibi görün, düşmanlarına korku ve dehşet sal! "/>
		<twn name=""/>
		<jap name=""/>
		<idn name=""/>
	</scenario_list>
