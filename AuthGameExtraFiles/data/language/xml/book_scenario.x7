		<scenario_list key="5000120">
        <kor name="Street Style Normal" data=""/>
		<ger name="Street Style Normal" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Modische Street Fashion.{N}Eine perfekte Mischung aus Freizeitlook und Eleganz.{N}Für den Modebewussten genau das Richtige!"/>
        <eng name="Street Style Normal" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}A hip, streetwise outfit.{N}The perfect mix of casual and chic, it allows you to move in style.{N}Show 'em who's boss in your Street Style costume!"/>
		<fre name="Street Style Normal" data="{N}{A-L}{F-2002_11}{CB-255,255,255,255}Costume Trendy Street Fashion.{N}Ensemble combinant un style décontracté et chic.{N}Vous serez à la pointe de la mode dans ce costume !"/>
