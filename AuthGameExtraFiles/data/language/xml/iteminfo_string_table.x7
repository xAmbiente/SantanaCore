	<string key="NAME312" ger="Remove the nickname change" eng="Remove the nickname change" />
	<string key="TIP312" ger="Die Nickänderung rückgängig machen und zum vorherigen Nick wechseln. Auch wenn das Item selber weggeworfen wird, bleibt der Effekt der Nickänderung erhalten." eng="Remove the nickname change effect and change your current nickname to previous one. Even if you delete the item by &quot;drop&quot; function, the nickname change effect still remains." />
	<string key="F_TEXT312"/>
	<string key="NAME313" ger="1Day  Change Nickname" eng="1Day  Change Nickname" />
	<string key="TIP313" ger="Der geänderte Nickname bleibt einen Tag erhalten." eng="Changed nickname is available for a day." />
	<string key="F_TEXT313"/>
	<string key="NAME314" ger="7Days Change Nickname" eng="7Days Change Nickname" />
	<string key="TIP314" ger="Der geänderte Nickname bleibt 7 Tage erhalten." eng="Changed nickname is available for 7 days." />
