	<string key="N4059005" ger="EC's Handsome Faces (M) Capsule" eng="EC's Handsome Faces (M) Capsule" />
	<string key="T4059005" ger="Holt jetzt die großartige Enigma Kapsel! Gewinnt eines der folgenden, tollen Preisen! {N}{N}{CB-255,0,0,255}Hinweis:{CB-255,255,255,255} 100% Unique Booster kann für diese Kapsel nicht genutzt werden. " eng="Get this awesome Enigma Capsule now! Win one of the amazing prizes listed below! {N}{N}{CB-255,0,0,255}Note:{CB-255,255,255,255} the 100% Unique Booster cannot be used on this capsule." />
	<string key="N4059006" ger="EC's Cute Faces (F) Capsule" eng="EC's Cute Faces (F) Capsule" />
	<string key="T4059006" ger="Holt jetzt die großartige Enigma Kapsel! Gewinnt eines der folgenden, tollen Preisen! {N}{N}{CB-255,0,0,255}Hinweis:{CB-255,255,255,255} 100% Unique Booster kann für diese Kapsel nicht genutzt werden. " eng="Get this awesome Enigma Capsule now! Win one of the amazing prizes listed below! {N}{N}{CB-255,0,0,255}Note:{CB-255,255,255,255} the 100% Unique Booster cannot be used on this capsule." />
	<string key="N4059007" ger="EC's Accessories (M) Capsule" eng="EC's Accessories (M) Capsule" />
	<string key="T4059007" ger="Holt jetzt die großartige Enigma Kapsel! Gewinnt eines der folgenden, tollen Preisen! {N}{N}{CB-255,0,0,255}Hinweis:{CB-255,255,255,255} 100% Unique Booster kann für diese Kapsel nicht genutzt werden. " eng="Get this awesome Enigma Capsule now! Win one of the amazing prizes listed below! {N}{N}{CB-255,0,0,255}Note:{CB-255,255,255,255} the 100% Unique Booster cannot be used on this capsule." />
