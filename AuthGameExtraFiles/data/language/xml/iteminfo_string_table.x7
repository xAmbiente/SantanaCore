	<string key="N2000067" ger="Lucifer Blue" eng="Lucifer Blue" />
	<string key="T2000067" ger="Dieses Bayonett symbolisiert die Arroganz der Korrumpierten.  Es ist dunkel und vibriert vor Macht." eng="A bayonet symbolizing the arrogance of the corrupted ones.  Though dark, it gives off a powerful energy." />
	<string key="N2000068" ger="Lucifer Green" eng="Lucifer Green" />
