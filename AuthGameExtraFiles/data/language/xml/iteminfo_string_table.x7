	<string key="N4340002" ger="Enchant Extractor" eng="Enchant Extractor" />
	<string key="T4340002" ger="Verzauberungseffekt von der Ausrüstung entfernen. Der von der Ausrüstung entfernte Verzauberungseffekt wurde zurückgesetzt." eng="Allows you to extract enchantments from equipment. Afterwards, the equipment's enchant stats will be reset." />
	<string key="N4340003" />
	<string key="T4340003"/>
	<string key="N4190001" ger="Enchant Chip - Melee" eng="Enchant Chip - Melee" />
	<string key="T4190001" ger="Benutze diesen Chip, um ein Item zu verbessern.{N}{N}{CB-255,0,0,255} Nur für Nahkampf-Waffen geeignet." eng="Use this Chip to enchant an item.{N}{N}{CB-255,0,0,255} For Melee weapons only." />
	<string key="N4200001" ger="Enchant Chip - Rifle" eng="Enchant Chip - Rifle" />
	<string key="T4200001" ger="Benutze diesen Chip, um ein Item zu verbessern.{N}{N}{CB-255,0,0,255} Nur für Gewehre geeignet." eng="Use this Chip to enchant an item.{N}{N}{CB-255,0,0,255} For Rifle weapons only." />
