	<string key="NAME304" ger="Skill Mastery" eng="Skill Mastery" />
	<string key="TIP304" ger="Ein passiver Skill, der ohne dein Zutun wirksam ist. SP werden erhöht und die Anwendungsdauer und -frequenz der Basic Actions werden verbessert." eng="A passive skill that will be effective simply by wearing it, you don't need to activate it. Max SP is increased so that your skills will occur more often and last longer." />
	<string key="F_TEXT304"/>
	<string key="NAME305" ger="PEN Plus 50" eng="PEN Plus 50" />
	<string key="TIP305" ger="Nach Benutzung dieses Items erhöht sich die PEN-Rate um 50%" eng="When you wear this boost item, you will gain PEN 50% faster." />
	<string key="F_TEXT305" ger="Use for 10hours" eng="Use for 10hours" />
	<string key="NAME306" ger="PEN Plus 100" eng="PEN Plus 100" />
	<string key="TIP306" ger="Nach Benutzung dieses Items erhöht sich die PEN-Rate um 100%" eng="When you wear this boost item, you will gain PEN 100% faster." />
	<string key="F_TEXT306" ger="Use for 10hours" eng="Use for 10hours" />
	<string key="NAME307" ger="Change Nickname" eng="Change Nickname" />
	<string key="TIP307" ger="Die Namensänderung bleibt bestehen." eng="This will change your nickname permanently." />
	<string key="F_TEXT307"/>
	<string key="NAME308" ger="Death Match-Statistik zurücksetzen" eng="Reset the Death Match History" />
	<string key="TIP308" ger="Item zurücksetzen (Death Match)" eng="Reset Item (Death Match)" />
	<string key="F_TEXT308"/>
	<string key="NAME309" ger="EXP Plus 30" eng="EXP Plus 30" />
	<string key="TIP309" ger="Nach Benutzung dieses Items erhöht sich die EXP-Rate um 30%." eng="When you wear this boost item, you will gain EXP 30% faster." />
	<string key="F_TEXT309" ger="Use for 10hours" eng="Use for 10hours" />
